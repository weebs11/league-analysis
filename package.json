{
  "name": "lol-matchup-coach",
  "productName": "LoL Matchup Coach",
  "version": "1.0.0",
  "description": "A local companion app that detects your active League of Legends game and coaches you through matchups, strategy, and itemization — built for players who are still learning the game.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "app": "electron .",
    "dist": "electron-builder",
    "test": "node --test --test-concurrency=1 test/*.test.js"
  },
  "build": {
    "appId": "com.lolmatchupcoach.app",
    "productName": "LoL Matchup Coach",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "server.js",
      "src/**",
      "public/**",
      "briefings/**",
      "!config.json",
      "!data/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "deleteAppDataOnUninstall": false,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  }
}
